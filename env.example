# FreightFlow Environment Variables
# Copy this file to .env.local (frontend) or .env (backend) and fill in your values.
# Never commit real secrets to version control.

# ─── FRONTEND (frontend/.env.local) ──────────────────────────────────────────

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stellar
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_FREIGHTFLOW_PLATFORM_ADDRESS=GPLACEHOLDER

# Trustless Work
NEXT_PUBLIC_TRUSTLESS_WORK_API_KEY=your-trustless-work-api-key
NEXT_PUBLIC_TRUSTLESS_NETWORK=testnet

# ─── BACKEND (backend/.env) ──────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/freightflow

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stellar
STELLAR_NETWORK=testnet
STELLAR_SECRET_KEY=SPLACEHOLDER

# Server
PORT=4000
NODE_ENV=development
